<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PERMISOS REQUERIDOS POR IRIS                           -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <!-- Acceso a la cámara del dispositivo (captura de fotogramas) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Acceso a internet (envío de fotogramas a la API de visión) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Permiso para grabar audio (Reconocimiento de voz) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Vibración para retroalimentación háptica -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Mantener pantalla encendida durante la asistencia -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Indicar que la app requiere hardware de cámara -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <application
        android:label="Iris"
        android:name="${applicationName}"
        android:icon="@mipmap/launcher_icon"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait">

            <!-- Tema del splash screen mientras carga Flutter -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Plugin de Flutter para mantener alineación -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <!-- Queries necesarios para TTS y STT en Android 11+ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

</manifest>
